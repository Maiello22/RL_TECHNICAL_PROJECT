      <visual name="leg_fr">
        <pose>0.5 -0.35 0.18 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.06 0.4</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
      
      <visual name="leg_rl">
        <pose>-0.5 0.35 0.18 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.06 0.4</size>
