<?xml version="1.0"?>
<sdf version="1.6">
  <model name="welding_station">
    <pose>-4 -4 0.1 0 0 0</pose>
    <static>false</static>
    
    <!-- ========================================== -->
    <!-- BASE E TAVOLO -->
    <!-- ========================================== -->
    <link name="base">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>120.0</mass>
        <inertia>
          <ixx>10.0</ixx>
          <iyy>10.0</iyy>
          <izz>15.0</izz>
        </inertia>
      </inertial>
      
      <!-- Piano di lavoro in acciaio -->
      <visual name="work_table">
        <pose>0 0 0.4 0 0 0</pose>
        <geometry>
          <box>
            <size>1.2 0.8 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.35 0.35 0.35 1</ambient>
          <diffuse>0.45 0.45 0.45 1</diffuse>
        </material>
      </visual>
      
      <!-- Griglia fessurata sul piano -->
      <visual name="grid_slots">
