          <box>
            <size>1.2 1.0 0.15</size>
          </box>
        </geometry>
      </collision>
      
      <collision name="frame_collision">
        <pose>0 0 1.2 0 0 0</pose>
        <geometry>
          <box>
            <size>1.2 1.0 2.4</size>
          </box>
        </geometry>
      </collision>
      
      <collision name="table_collision">
        <pose>0 0 0.5 0 0 0</pose>
        <geometry>
          <box>
            <size>0.8 0.8 0.08</size>
