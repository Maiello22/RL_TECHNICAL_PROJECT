        </material>
      </visual>
      
      <!-- Targhetta dati tecnici -->
      <visual name="nameplate">
        <pose>0.61 0 0.72 0 0 0</pose>
        <geometry>
          <box>
            <size>0.001 0.15 0.1</size>
