<?xml version="1.0"?>
<sdf version="1.6">
  <model name="hydraulic_press">
    <pose>-2 4 0.1 0 0 0</pose>
    <static>false</static>
    
    <!-- ========================================== -->
    <!-- BASE E STRUTTURA -->
    <!-- ========================================== -->
    <link name="base">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>500.0</mass>
        <inertia>
          <ixx>50.0</ixx>
          <iyy>50.0</iyy>
          <izz>80.0</izz>
        </inertia>
      </inertial>
      
      <!-- Basamento -->
      <visual name="base_platform">
        <geometry>
          <box>
            <size>1.2 1.0 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.35 0.35 0.35 1</diffuse>
        </material>
      </visual>
      
      <!-- Colonne laterali (frame C) -->
      <visual name="column_left">
        <pose>-0.5 0 1.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.15 1.0 2.4</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.25 0.3 1</ambient>
          <diffuse>0.2 0.35 0.4 1</diffuse>
        </material>
      </visual>
      
      <visual name="column_right">
        <pose>0.5 0 1.2 0 0 0</pose>
        <geometry>
          <box>
            <size>0.15 1.0 2.4</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.25 0.3 1</ambient>
          <diffuse>0.2 0.35 0.4 1</diffuse>
        </material>
      </visual>
      
      <!-- Traversa superiore -->
      <visual name="top_beam">
        <pose>0 0 2.35 0 0 0</pose>
        <geometry>
          <box>
            <size>1.2 1.0 0.2</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.25 0.3 1</ambient>
          <diffuse>0.2 0.35 0.4 1</diffuse>
        </material>
      </visual>
      
      <!-- Rinforzi angolari -->
      <visual name="brace_fl">
        <pose>-0.43 0.43 0.4 0 0.7854 0.7854</pose>
        <geometry>
          <box>
            <size>0.08 0.08 0.6</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.3 0.35 1</ambient>
          <diffuse>0.3 0.4 0.45 1</diffuse>
        </material>
      </visual>
      
      <visual name="brace_fr">
        <pose>0.43 0.43 0.4 0 -0.7854 -0.7854</pose>
        <geometry>
          <box>
            <size>0.08 0.08 0.6</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.3 0.35 1</ambient>
          <diffuse>0.3 0.4 0.45 1</diffuse>
        </material>
      </visual>
      
      <!-- Piano di lavoro fisso -->
      <visual name="work_table">
        <pose>0 0 0.5 0 0 0</pose>
        <geometry>
          <box>
            <size>0.8 0.8 0.08</size>
          </box>
        </geometry>
        <material>
          <ambient>0.35 0.35 0.35 1</ambient>
          <diffuse>0.45 0.45 0.45 1</diffuse>
        </material>
      </visual>
      
      <!-- Scanalature sul piano -->
      <visual name="slot1">
        <pose>-0.2 0 0.54 0 0 0</pose>
        <geometry>
          <box>
            <size>0.03 0.7 0.005</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
      
      <visual name="slot2">
        <pose>0.2 0 0.54 0 0 0</pose>
        <geometry>
          <box>
            <size>0.03 0.7 0.005</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
      
      <!-- Cilindro idraulico principale -->
      <visual name="hydraulic_cylinder">
        <pose>0 0 1.9 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.8</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.65 1</ambient>
          <diffuse>0.7 0.7 0.75 1</diffuse>
        </material>
