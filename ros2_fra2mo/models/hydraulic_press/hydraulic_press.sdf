        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      
      <!-- Pulsanti -->
      <visual name="button_up">
        <pose>0.72 0 0.88 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.02</radius>
            <length>0.015</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.8 0.2 1</ambient>
          <diffuse>0.3 0.9 0.3 1</diffuse>
          <emissive>0.1 0.3 0.1 1</emissive>
        </material>
      </visual>
      
      <visual name="button_down">
        <pose>0.72 0 0.85 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.02</radius>
            <length>0.015</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.2 1</ambient>
          <diffuse>0.9 0.9 0.3 1</diffuse>
          <emissive>0.3 0.3 0.1 1</emissive>
        </material>
      </visual>
      
      <visual name="button_emergency">
        <pose>0.72 0.1 0.82 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.1 0.1 1</ambient>
          <diffuse>1.0 0.2 0.2 1</diffuse>
          <emissive>0.4 0.1 0.1 1</emissive>
        </material>
      </visual>
      
      <!-- Manometro -->
      <visual name="pressure_gauge">
        <pose>-0.5 0.25 0.6 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      
      <visual name="gauge_face">
        <pose>-0.485 0.25 0.6 0 1.5708 0</pose>
        <geometry>
