          <emissive>0.05 0.05 0.05 1</emissive>
        </material>
      </visual>
      
      <!-- Testa del pistone (parte mobile) -->
      <visual name="ram_head">
        <pose>0 0 0.85 0 0 0</pose>
        <geometry>
          <box>
            <size>0.7 0.7 0.12</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>
      
      <!-- Piastra superiore di pressione -->
      <visual name="pressure_plate">
        <pose>0 0 0.79 0 0 0</pose>
        <geometry>
          <box>
            <size>0.6 0.6 0.04</size>
