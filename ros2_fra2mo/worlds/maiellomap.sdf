<?xml version="1.0" ?>
<sdf version="1.5">
  <world name="maiellomap">
    
    <physics name='default_physics' default='0' type='ode'>
      <gravity>0 0 -9.8066</gravity>
      <ode>
        <solver>
          <type>quick</type>
          <iters>10</iters>
          <sor>1.3</sor>
          <use_dynamic_moi_rescaling>0</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
      <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    </physics>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <include>
      <name>race_field</name>
      <pose> 10 5 0.1 0 0 3.14159 </pose>
      <uri>model://race_field</uri>
    </include>
    
    <!-- Roof -->
     <include>
      <name>roof</name>
      <pose> 10 -5 3.1 3.14159 0 3.14159 </pose>
      <uri>model://roof</uri>
    </include>
<!-- MACCHINARI INDUSTRIALI -->
    <include>
      <name>drill_press</name>
      <pose>1.2 3 0.3 0 0 0</pose>
      <uri>model://drill_press</uri>
    </include>

<!--     <include>
      <name>conveyor_belt</name>
      <pose>-5 -2 0.3 0 0 1.57</pose>      
      <uri>model://conveyor_belt</uri>
    </include>
 -->
    <include>
      <name>hydraulic_press</name>
      <pose>8.88 -2.3 0.2 0 0 -1.57</pose>      
      <uri>model://hydraulic_press</uri>
    </include>
<!-- 
    <include>
      <name>welding_station</name>
      <pose>6 -4 0.3 0 0 0</pose>   
      <uri>model://welding_station</uri>
    </include>
   -->





      
    <!-- AR markers -->
<!--     <include>
      <name>tool_0_tag</name>
      <uri>model://aruco_tag_1</uri>
      <pose>-8 -2 0.2 0 -1.57 0</pose>
    </include> -->


  <model name="aruco_cube">
    <static>false</static>
    <pose>1 -2.15 0.4 0 0 0</pose>

    <!-- ============================================ -->
    <!--           CUBO ARUCO (PRINCIPALE)          -->
    <!-- ============================================ -->
    <link name="cube_link">
      <!-- INERTIA -->
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.01</ixx>
          <iyy>0.01</iyy>
          <izz>0.01</izz>
        </inertia>
      </inertial>

      <!-- VISUAL -->
      <visual name="cube_visual">
        <geometry>
          <box>
            <size>0.3 0.3 0.3</size>
          </box>
        </geometry>

        <material>
          <diffuse>1 1 1 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>

          <!-- TEXTURE ARUCO -->
          <pbr>
            <metal>
              <albedo_map>
                model://aruco_tag_1/aruco_tag_id10.png
              </albedo_map>
              <metalness>0.0</metalness>
              <roughness>0.8</roughness>
            </metal>
          </pbr>
        </material>
      </visual>

      <!-- COLLISION -->
      <collision name="cube_collision">
        <geometry>
          <box>
            <size>0.3 0.3 0.3</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- ============================================ -->
    <!--         BASE DEL PULSANTE (NUOVO)          -->
    <!-- ============================================ -->
    <link name="button_base">
      <!-- ✅ POSIZIONE INVARIATA SUL CUBO -->
      <pose>-0.08 -0.08 0.18 0 0 0</pose>
      
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      
      <!-- Pannello posteriore -->
      <visual name="back_panel">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.12 0.12 0.04</size>
          </box>
        </geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.35 0.35 0.35 1</diffuse>
        </material>
      </visual>
      
      <!-- Supporto anello -->
      <visual name="support_ring">
        <pose>0 0 0.03 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
      
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.12 0.12 0.04</size>
          </box>
        </geometry>
      </collision>
    </link>
    
    <!-- ============================================ -->
    <!--      BOTTONE PREMIBILE (NUOVO)             -->
    <!-- ============================================ -->
    <link name="button_top">
      <pose>-0.08 -0.08 0.235 0 0 0</pose>
      
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <iyy>0.0001</iyy>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      
      <!-- Bottone principale -->
      <visual name="button_head">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.2 0.2 1</ambient>
          <diffuse>1.0 0.25 0.25 1</diffuse>
          <emissive>0.3 0.05 0.05 1</emissive>
        </material>
      </visual>
      
      <!-- Bordo bottone -->
      <visual name="button_edge">
        <pose>0 0 0.013 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.041</radius>
            <length>0.001</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      
      <!-- Collision -->
      <collision name="button_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <contact>
            <ode>
              <kp>100000</kp>
              <kd>100</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      
      <!-- ✅ SENSORE DI CONTATTO -->
      <sensor name="button_touch_sensor" type="contact">
        <contact>
          <collision>button_collision</collision>
        </contact>
        <update_rate>50</update_rate>
        <always_on>true</always_on>
      </sensor>
    </link>

    <!-- ============================================ -->
    <!--         LED INDICATORE (NUOVO)              -->
    <!-- ============================================ -->
    <link name="led">
      <pose>-0.025 -0.08 0.245 0 0 0</pose>
      
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.000001</ixx>
          <iyy>0.000001</iyy>
          <izz>0.000001</izz>
        </inertia>
      </inertial>
      
      <visual name="led_visual">
        <geometry>
          <sphere>
            <radius>0.006</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <emissive>0 0 0 1</emissive>
        </material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!--              JOINTS                         -->
    <!-- ============================================ -->
    
    <!-- Joint: Cubo -> Base pulsante (fisso) -->
    <joint name="cube_to_button_base" type="fixed">
      <parent>cube_link</parent>
      <child>button_base</child>
    </joint>
    
    <!-- Joint: Base -> Bottone (prismatico con molla) -->
    <joint name="button_joint" type="prismatic">
      <parent>button_base</parent>
      <child>button_top</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0.012</upper>
          <effort>150</effort>
          <velocity>0.3</velocity>
        </limit>
        <dynamics>
          <!-- ✅ Molla che riporta il pulsante in posizione -->
          <spring_reference>0.012</spring_reference>
          <spring_stiffness>800</spring_stiffness>
          <damping>30</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
        </ode>
      </physics>
    </joint>
    
    <!-- Joint: Base -> LED (fisso) -->
    <joint name="led_joint" type="fixed">
      <parent>button_base</parent>
      <child>led</child>
    </joint>

    <!-- ============================================ -->
    <!--         PLUGIN ROS2 (NUOVO)                 -->
    <!-- ============================================ -->
    <plugin 
      filename="libgz-sim-joint-state-publisher-system.so" 
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>button_joint</joint_name>
      <topic>/aruco_cube_button/joint_states</topic>
      <update_rate>50</update_rate>
    </plugin>

  </model>















  <!-- ****************************** -->
  <!--       apparecchi industriali      -->
  <!-- ****************************** -->
  <model name="industrial_pallet">
    <pose>-9 4.42 0.1 0 0 0</pose>
    <static>false</static>
    
    <!-- Piano superiore del pallet -->
    <link name="top_deck">
      <pose>0 0 0.065 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.5</ixx>
          <iyy>0.5</iyy>
          <izz>0.8</izz>
        </inertia>
      </inertial>
      <visual name="top_visual">
        <geometry>
          <box>
            <size>1.2 0.8 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.6 0.4 0.2 1</ambient>
          <diffuse>0.7 0.5 0.3 1</diffuse>
        </material>
      </visual>
      <collision name="top_collision">
        <geometry>
          <box>
            <size>1.2 0.8 0.02</size>
          </box>
        </geometry>
      </collision>
    </link>
    
    <!-- Traversa 1 -->
    <link name="beam1">
      <pose>-0.4 0 0.03 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.05</izz>
        </inertia>
      </inertial>
      <visual name="beam1_visual">
