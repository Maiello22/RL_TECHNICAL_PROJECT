          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.35 0.15 1</ambient>
          <diffuse>0.6 0.4 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="beam1_collision">
        <geometry>
          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
      </collision>
    </link>
    
    <!-- Traversa 2 -->
    <link name="beam2">
      <pose>0 0 0.03 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.05</izz>
        </inertia>
      </inertial>
      <visual name="beam2_visual">
        <geometry>
          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.35 0.15 1</ambient>
          <diffuse>0.6 0.4 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="beam2_collision">
        <geometry>
          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
      </collision>
    </link>
    
    <!-- Traversa 3 -->
    <link name="beam3">
      <pose>0.4 0 0.03 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.05</izz>
        </inertia>
      </inertial>
      <visual name="beam3_visual">
        <geometry>
          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.35 0.15 1</ambient>
          <diffuse>0.6 0.4 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="beam3_collision">
        <geometry>
          <box>
            <size>0.1 0.8 0.06</size>
          </box>
        </geometry>
      </collision>
    </link>
    
    <!-- Giunti fissi tra le parti -->
    <joint name="beam1_to_top" type="fixed">
      <parent>top_deck</parent>
      <child>beam1</child>
    </joint>
    
    <joint name="beam2_to_top" type="fixed">
      <parent>top_deck</parent>
      <child>beam2</child>
    </joint>
    
    <joint name="beam3_to_top" type="fixed">
      <parent>top_deck</parent>
      <child>beam3</child>
    </joint>
  </model>

