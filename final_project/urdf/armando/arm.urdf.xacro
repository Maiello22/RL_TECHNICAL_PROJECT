<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="armando">
  
  <!-- Argomenti che verranno passati dal launch file -->
  <xacro:arg name="namespace" default=""/>
  <xacro:arg name="yaml_file" default=""/>
  
  <!-- Proprietà locali -->

  <xacro:property name="namespace_value" value="$(arg namespace)"/>
  <xacro:property name="prefix" value="$(arg namespace)_"/>
  <xacro:property name="yaml_path" value="$(arg yaml_file)"/>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <!-- ========================================================================= -->
  <!-- MATERIALS -->
  <!-- ========================================================================= -->
  <material name="red_base"><color rgba="0.8 0.0 0.0 1.0"/></material>
  <material name="black"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- ========================================================================= -->
  <!-- PROPERTIES -->
  <!-- ========================================================================= -->
  <xacro:property name="M_PI_2" value="1.570796327" /> 

  <xacro:property name="base_length" value="0.35" />
  <xacro:property name="base_width" value="0.25" />
  <xacro:property name="base_height" value="0.08" />
  <xacro:property name="base_mass" value="5.0" />

  <xacro:property name="wheel_radius" value="0.03" />
  <xacro:property name="wheel_width" value="0.025" />
  <xacro:property name="wheel_mass" value="5.0" />
  <xacro:property name="wheel_separation" value="0.24" />

  <xacro:property name="caster_radius" value="0.015" />
  <xacro:property name="caster_mass" value="0.3" />

  <xacro:property name="ground_clearance" value="0.000" />
  <xacro:property name="wheel_mount_z" value="${-base_height/2}" />
  <xacro:property name="base_elevation" value="${wheel_radius - wheel_mount_z + ground_clearance}" />

  <!-- ========================================================================= -->
  <!-- BASE FOOTPRINT (CON PREFIX) -->
  <!-- ========================================================================= -->
  <link name="${prefix}mobile_base_footprint"/>
  
  <joint name="${prefix}mobile_base_footprint_joint" type="fixed">
    <parent link="${prefix}mobile_base_footprint"/>
    <child link="${prefix}mobile_base_link"/>
    <origin xyz="0 0 ${base_elevation}" rpy="0 0 0"/>
  </joint>
  
  <!-- ========================================================================= -->
  <!-- BASE LINK (CON PREFIX) -->
  <!-- ========================================================================= -->
  <link name="${prefix}mobile_base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="red_base"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="${(1/12) * base_mass * (base_width*base_width + base_height*base_height)}" ixy="0.0" ixz="0.0"
               iyy="${(1/12) * base_mass * (base_length*base_length + base_height*base_height)}" iyz="0.0"
               izz="${(1/12) * base_mass * (base_length*base_length + base_width*base_width)}"/>
    </inertial>
  </link>
  
  <!-- ========================================================================= -->
  <!-- WHEEL MACRO -->
  <!-- ========================================================================= -->
  <xacro:macro name="wheel_link_joint" params="side origin_x y_sign">
    <link name="${prefix}${side}_wheel_link">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia ixx="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" iyz="0.0"
                 izz="${(1/2) * wheel_mass * wheel_radius * wheel_radius}"/>
      </inertial>
    </link>
    <joint name="${prefix}${side}_wheel_joint" type="continuous">
      <parent link="${prefix}mobile_base_link"/>
      <child link="${prefix}${side}_wheel_link"/>
      <origin xyz="${origin_x} ${y_sign * wheel_separation/2} ${wheel_mount_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>
  </xacro:macro>

  <!-- ========================================================================= -->
  <!-- WHEELS -->
  <!-- ========================================================================= -->
  <xacro:wheel_link_joint side="left" origin_x="0.05" y_sign="1"/>
  <xacro:wheel_link_joint side="right" origin_x="0.05" y_sign="-1"/>

  <!-- ========================================================================= -->
  <!-- CASTER -->
  <!-- ========================================================================= -->
  <link name="${prefix}caster_link">
    <visual><geometry><sphere radius="${caster_radius}"/></geometry><material name="black"/></visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <mass value="${caster_mass}"/>
      <inertia ixx="${(2/5) * caster_mass * caster_radius*caster_radius}" ixy="0.0" ixz="0.0" 
               iyy="${(2/5) * caster_mass * caster_radius*caster_radius}" iyz="0.0" 
               izz="${(2/5) * caster_mass * caster_radius*caster_radius}"/>
    </inertial>
  </link>

  <joint name="${prefix}caster_joint" type="fixed">
    <parent link="${prefix}mobile_base_link"/>
    <child link="${prefix}caster_link"/>
    <origin xyz="${-base_length/2 + 0.05} 0 ${caster_radius - base_elevation}" rpy="0 0 0"/>
  </joint>
  



  <!-- ========================================================================= -->
  <!-- ARM MOUNT POINT -->
  <!-- ========================================================================= -->
  <link name="${prefix}mount_point"/>
  
  <joint name="${prefix}mount_joint" type="fixed">
    <parent link="${prefix}mobile_base_link"/>
    <child link="${prefix}mount_point"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================================= -->
  <!-- ARM BASE LINK (DEL BRACCIO ROBOTICO) -->
  <!-- ========================================================================= -->
  <link name="${prefix}base_link">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size = "0.08 0.08 0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1.06682889e-04" ixy="0.0" ixz="0.0" iyy="9.92165844e-05" iyz="0.0" izz="1.26939175e-04"/>
    </inertial>    
  </link>

  <joint name="${prefix}base_1_2" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}base_turn"/>
    <origin xyz="-0.0011 -0.011 0.08"/>
  </joint>

  <link name="${prefix}base_turn">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/base_turn.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.05 0.08 0.008"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0 +0.011 0"/>
    </collision>   
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1.35223008e-05" ixy="0.0" ixz="0.0" iyy="8.13814925e-06" iyz="0.0" izz="2.14903814e-05"/>
    </inertial>
  </link>
 
  <joint name="${prefix}j0" type="revolute">
    <parent link="${prefix}base_turn"/>
    <child link="${prefix}base_turn_rot"/>
    <origin xyz="-0.0 0.0155 0.013" rpy = "0 0 -1.57"/>
    <axis xyz="0 0 1" />
    <limit effort="300" velocity="0.1" lower="-2.57" upper="2.57"/>
  </joint>

  <link name="${prefix}base_turn_rot">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/base_turn_table_rot.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.055 0.055 0.02"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="${prefix}base_turn_rot_dyn2" type="fixed">
    <parent link="${prefix}base_turn_rot"/>
    <child link="${prefix}dyn2"/>
    <origin xyz="0 0 0.0385" rpy="0 1.57 1.57 "/>
  </joint>

  <link name="${prefix}dyn2">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/dyn.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.05 0.031 0.035"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.01 0 0"/>
    </collision>
     <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
  
  <joint name="${prefix}j1" type="revolute">
    <parent link="${prefix}dyn2"/>
    <child link="${prefix}dyn2_r"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1" />
    <limit effort="300" velocity="0.1" lower="-3.14" upper="3.14"/>
  </joint>
  
  <link name="${prefix}dyn2_r">
    
  </link>

  <joint name="${prefix}dyn2_f4" type="fixed">
    <parent link="${prefix}dyn2_r"/>
    <child link="${prefix}f4"/>
    <origin xyz="-0.047 0.0 -0.003" rpy="0 1.57 1.57"/>
  </joint>

  <link name="${prefix}f4">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/f4_n_f3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.06 0.088 0.027"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0 -0.01 0"/>
    </collision>
     <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
  
  <joint name="${prefix}d4_dyn3" type="fixed">
    <parent link="${prefix}f4"/>
    <child link="${prefix}dyn3"/>
    <origin xyz="-0.004 0.0645 0 " rpy="-1.57 3.14 1.57"/>
  </joint>
  
  <link name="${prefix}dyn3">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/dyn.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.05 0.027 0.04"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.01 0 0"/>
    </collision>
     <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
  
  <joint name="${prefix}j2" type="revolute">
    <parent link="${prefix}dyn3"/>
    <child link="${prefix}dyn3_r"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1" />
    <limit effort="300" velocity="0.1" lower="-3.14" upper="3.14"/>
  </joint>
  
 <link name="${prefix}dyn3_r">

  </link>
  
  <joint name="${prefix}dyn3_f5" type="fixed">
    <parent link="${prefix}dyn3_r"/>
    <child link="${prefix}f5"/>
    <origin xyz="-0.046 -0.0 -0.002" rpy="1.57 1.57 3.1415 "/>
  </joint>

  <link name="${prefix}f5">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/f4_n_f3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.065 0.088 0.027"/>
        </geometry>
      <origin rpy="0 0 0" xyz="-0.005 -0.01 0"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
  <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>    </inertial>
  </link>
  
  <joint name="${prefix}f5_dyn4" type="fixed">
    <parent link="${prefix}f5"/>
    <child link="${prefix}dyn4"/>
    <origin xyz="-0.004 0.065 -0.0" rpy="-1.57 3.1415 1.57 "/>
  </joint> 
  
  <link name="${prefix}dyn4">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/dyn.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.05 0.029 0.037"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.01 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
  
  <joint name="${prefix}j3" type="revolute">
    <parent link="${prefix}dyn4"/>
    <child link="${prefix}dyn4_r"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1" />
    <limit effort="300" velocity="0.1" lower="-3.14" upper="3.14"/>
  </joint>
  
  <link name="${prefix}dyn4_r">
    
  </link>
  
  <joint name="${prefix}f5_wrist" type="fixed">
    <parent link="${prefix}dyn4_r"/>
    <child link="${prefix}wrist"/>
    <origin xyz="-0.017 -0.013 0.003" rpy="1.57 1.57 -1.57"/>
  </joint>

  <link name="${prefix}wrist">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/wrist.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size = "0.057 0.046 0.045"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 -0.01"/>
    </collision>
    
     <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
  
  <joint name="${prefix}wrist_dyn5" type="fixed">
    <parent link="${prefix}wrist"/>
    <child link="${prefix}dyn5"/>
    <origin xyz="0.0038 -0.013 0.0275" rpy="0 0 1.57"/>
  </joint>

    <link name="${prefix}dyn5">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/dyn.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.05 0.031 0.04"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.01 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>
 
  <joint name="${prefix}dyn5_dyn5_r" type="fixed">
    <parent link="${prefix}dyn5"/>
    <child link="${prefix}dyn5_r"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1" />
    <limit effort="300" velocity="0.1" lower="-3.14" upper="3.14"/>
  </joint>
  
  <link name="${prefix}dyn5_r">
    
  </link>
  
  <joint name="${prefix}wrist_rotate_dyn5" type="fixed">
    <parent link="${prefix}dyn5_r"/>
    <child link="${prefix}crawer_base"/>
    <origin xyz="0.015 0 0.019" rpy="0 0 1.57"/>
  </joint>
    
  <link name="${prefix}crawer_base">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/the_crawer_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
          <box size = "0.102 0.052 0.007"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>

  <joint name="${prefix}gripper_left_joint" type="prismatic">
    <parent link="${prefix}crawer_base"/>
    <child link="${prefix}crawer_left"/>
    <origin xyz="-0.03 0.015 0.01" rpy="0 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="0.05" lower="0.0" upper="0.03"/>
  </joint>
  
  <link name="${prefix}crawer_left">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/the_crawer.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
          <box size = "0.057 0.031 0.042"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.02 0 0.01"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>

  <joint name="${prefix}gripper_right_joint" type="prismatic">
    <parent link="${prefix}crawer_base"/>
    <child link="${prefix}crawer_right"/>
    <origin xyz="0.03 0.015 0.01" rpy="3.1415 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="0.05" lower="0.0" upper="0.03"/>
  </joint>

  <link name="${prefix}crawer_right">
    <visual>
      <geometry>
        <mesh filename="file://$(find final_project)/meshes/armando/the_crawer.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
          <box size = "0.057 0.031 0.042"/>
        </geometry>
      <origin rpy="0 0 0" xyz="0.02 0 0.01"/>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.90013881e-05" ixy="0.0" ixz="0.0" iyy="1.24554875e-04" iyz="0.0" izz="1.04295793e-04"/>
    </inertial>
  </link>

  <!-- Joint che collega il braccio robotico alla base mobile -->
  <joint name="armando_fixed_mount" type="fixed">
    <parent link="${prefix}mount_point"/>
    <child link="${prefix}base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>








  <!-- ========================================================================= -->
  <!-- GAZEBO PLUGINS -->
  <!-- ========================================================================= -->

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg yaml_file)</parameters>      
      <ros>
      <namespace>$(arg namespace)</namespace>      
      </ros>
      <control_period>0.01</control_period>
    </plugin>
  </gazebo>

  <!-- Colori Gazebo -->
  <gazebo reference="${prefix}base_link">
    <material>Gazebo/Red</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
  </gazebo>

  <gazebo reference="${prefix}base_turn">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}base_turn_rot">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}dyn2">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="${prefix}dyn3">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="${prefix}dyn4">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="${prefix}dyn5">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="${prefix}f4">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}f5">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}wrist">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}crawer_base">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="${prefix}crawer_left">
    <material>Gazebo/White</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="${prefix}crawer_right">
    <material>Gazebo/White</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>



  <!-- GAZEBO MATERIALS FOR MOBILE BASE -->
  <gazebo reference="${prefix}mobile_base_link">
    <material>Gazebo/Red</material>
  </gazebo>
  
  <gazebo reference="${prefix}left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="${prefix}right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  
  <gazebo reference="${prefix}caster_link">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- DIFFDRIVE PLUGIN -->
  <gazebo>
    <plugin name="ignition::gazebo::systems::DiffDrive" filename="libignition-gazebo-diff-drive-system.so">
      <left_joint>${prefix}left_wheel_joint</left_joint>
      <right_joint>${prefix}right_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.03</wheel_radius>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
      <min_linear_acceleration>-2.0</min_linear_acceleration>
      <min_angular_acceleration>-3.0</min_angular_acceleration>
      <topic>/$(arg namespace)/cmd_vel</topic>
      <odom_topic>/$(arg namespace)/odom</odom_topic>
      <tf_topic>/$(arg namespace)/tf</tf_topic>
      <frame_id>/arm/odom</frame_id>
      <child_frame_id>${prefix}mobile_base_footprint</child_frame_id>
      <odom_publish_frequency>50.0</odom_publish_frequency>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>
  </gazebo>

  <!-- ros2_control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <joint name="${prefix}j0">
      <command_interface name="position">
        <param name="min">-2.57</param>
        <param name="max">2.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="${prefix}j1">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="${prefix}j2">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
    <joint name="${prefix}j3">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="${prefix}gripper_left_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.03</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="${prefix}gripper_right_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.03</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="${prefix}left_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="${prefix}right_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>
  



  <!-- ========================================================================= -->
  <!-- LIDAR LINK -->
  <!-- ========================================================================= -->
  <link name="${prefix}lidar_link">
      <visual>
          <geometry>
              <cylinder radius="0.04" length="0.04"/>
          </geometry>
          <material name="black"/>
          <origin xyz="0.13 0 0" rpy="0 0 0"/>
      </visual>
      <collision>
          <geometry>
              <cylinder radius="0.04" length="0.04"/>
          </geometry>
          <origin xyz="0.13 0 0" rpy="0 0 0"/>
      </collision>
      <inertial>
          <mass value="0.1"/>
          <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                  iyy="0.0001" iyz="0.0"
                  izz="0.0001"/>
      </inertial>
  </link>

  <joint name="${prefix}lidar_joint" type="fixed">
      <parent link="${prefix}mobile_base_link"/>
      <child link="${prefix}lidar_link"/>
      <origin xyz="0.0 0.0 ${base_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================================= -->
  <!-- LIDAR GAZEBO PLUGIN -->
  <!-- ========================================================================= -->
  <gazebo reference="${prefix}lidar_link">
      <sensor name="lidar" type="gpu_lidar">
          <topic>$(arg namespace)/scan</topic>
          <update_rate>10</update_rate>
          <lidar>
              <scan>
                  <horizontal>
                      <samples>360</samples>
                      <resolution>1.0</resolution>
                      <min_angle>-3.14159</min_angle>
                      <max_angle>3.14159</max_angle>
                  </horizontal>
              </scan>
              <range>
                  <min>0.12</min>
                  <max>10.0</max>
                  <resolution>0.015</resolution>
              </range>
              <noise>
                  <type>gaussian</type>
                  <mean>0.0</mean>
                  <stddev>0.01</stddev>
              </noise>
          </lidar>
          <always_on>1</always_on>
          <visualize>true</visualize>
      </sensor>
      <material>Gazebo/Black</material>
  </gazebo>




  
</robot>